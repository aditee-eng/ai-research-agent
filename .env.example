# ============================================================
#  .env.example
#  Copy this file to .env and fill in your real API keys.
#  Never commit your actual .env file to version control!
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Get your OpenAI API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Get your SerpAPI key at: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your_serpapi_api_key_here

# ── Optional (defaults shown) ────────────────────────────────
# LLM model to use. Options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Max tokens for each LLM response (higher = longer outputs, more cost)
MAX_TOKENS=2000

# LLM temperature: 0.0 = deterministic, 1.0 = very creative
TEMPERATURE=0.3

# How many web-search results to fetch per query
NUM_SEARCH_RESULTS=5

# Directory where finished reports are saved
REPORTS_DIR=reports
